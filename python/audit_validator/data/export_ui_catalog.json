        "Go to Manage → Usage activity → Fonts tab.",
        "Open a font usage row and open the drawer → Projects tab.",
        "Click Export data."
      ]
    },
    "exportFontUsers": {
      "touchpoint": "Discovery/Browse (global)",
      "url_hint": "/manage/usage-activity/fonts",
      "button": "Export data",
