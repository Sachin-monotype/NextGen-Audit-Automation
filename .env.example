# ── MongoDB (audit log storage) ──────────────────────────────────────────────
MONGO_DB_URL=mongodb://localhost:27017
MONGO_DB_NAME=AuditLogsPreprod
MONGO_COLLECTION_RAW=raw
MONGO_COLLECTION_ENRICHED=enriched
MONGO_COLLECTION_DLQ=dlq

# Validator project root — defaults to this repo (python/audit_validator is vendored here)
AUDIT_PROJECT_ROOT=.

# ── UI / API ───────────────────────────────────────────────────────────────────
API_PORT=3200
API_DEFAULT_PAGE_SIZE=20
API_MAX_PAGE_SIZE=200
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Target environment (pp | qa | uat) ───────────────────────────────────────
# Switched from the Generate UI. Also selects Mongo DB:
#   pp  → AuditLogsPreprod + https://nextgen.monotype-pp.com
#   qa  → AuditLogsQA      + https://nextgen-qa.monotype-pp.com
#   uat → AuditLogsUAT     + https://nextgen.monotype-uat.com
AUDIT_TARGET=pp

# ── GraphQL (overridden by AUDIT_TARGET profile) ──────────────────────────────
NEXTGEN_UI_URL=https://nextgen.monotype-pp.com
GRAPHQL_ENDPOINT=https://nextgen.monotype-pp.com/graphql
NEXTGEN_GRAPHQL_ENDPOINT=https://nextgen.monotype-pp.com/graph
NEXTGEN_ORIGIN=https://nextgen.monotype-pp.com
NEXTGEN_REFERER=https://nextgen.monotype-pp.com/discover-fonts/all

# Bearer tokens — required for simulation
BEARER_TOKEN=
# NEXTGEN_BEARER_TOKEN=

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqps://user:pass@rabbitmq-preprod.monotype-pp.com:5671/mt-connect-preprod
# Platform mains (reference only): mt.platform.raw_events.resolver.queue /
#   mt.platform.events.notification.queue
# Automation / Mongo taps (comma is part of the name):
RAW_EVENTS_QUEUE=mt.platform,resolver.raw_events_test_queue
ENRICHED_EVENTS_QUEUE=mt.platform,resolver.enriched_events_test_queue
RAW_QUEUE_PASSIVE=true
ENRICHED_QUEUE_PASSIVE=true

# ── Ingestion service (RabbitMQ → Mongo, ported from audit-sense) ─────────────
# Subscription queues with catch-all routing — every event is persisted to Mongo,
# which is what keeps complete raw+enrich pairs available to validate.
INGEST_RAW_QUEUE=mt.platform,resolver.raw_events_test_queue
INGEST_ENRICHED_QUEUE=mt.platform,resolver.enriched_events_test_queue
INGEST_DLQ_QUEUE=mt.platform.raw_events.resolver.dlq
INGEST_PREFETCH=100
INGEST_BATCH_FLUSH_INTERVAL_MS=5000
INGEST_CLEANUP_INTERVAL_MS=30000
INGEST_CLEANUP_MAX_DOCS_PER_OPERATION=20
# Backend hourly Mongo retention sweep (runs even when ingestion is off).
MONGO_RETENTION_MAX_DOCS_PER_OPERATION=20
MONGO_RETENTION_INTERVAL_SEC=3600
# Purge each subscription queue's backlog when ingestion starts.
INGEST_PURGE_ON_START=false
# Auto-start RabbitMQ → Mongo dump when the backend boots (Generate verify needs this).
INGEST_AUTO_START=true

# ── Simulation seeds ──────────────────────────────────────────────────────────
SEED_FAMILY_ID=794981
SEED_DEACTIVATE_FAMILY_ID=
SEED_STYLE_ID=
GRAPHQL_CONTEXT_CUSTOMER_ID=

# ── Source validation APIs ────────────────────────────────────────────────────
DISCOVERY_BASE_URL=https://mtc-middleware-discovery.monotype-pp.com
UMS_BASE_URL=https://usermanagement-pp.monotype.com
CMS_BASE_URL=https://customermanagement-preprod.monotype.com

# Source truth for Compare: api (HTTP) | db (MySQL for UMS/CMS/AMS; Typesense stays HTTP)
# SOURCE_TRUTH=api
# MYSQL_HOST=mosaicmysqlrdspreprod.cn8kri9cz75n.us-east-1.rds.amazonaws.com
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=asteria@asteria   # PPConfig default (not plain "asteria")
# FB / Font Bridge alternate: user zeus / password zeus@mt.comppdb (app_config.FB_DB_*)
# MYSQL_SSL=true

# ── Pipeline timing ───────────────────────────────────────────────────────────
EVENT_WAIT_TIMEOUT_MS=30000
PYTHON_SETTLE_SEC=120
ENRICHED_CATCHUP_SEC=180
# After Generate: poll Mongo for owned xCorrelationId in raw + enriched
GENERATE_VERIFY_TIMEOUT_SEC=90
GENERATE_VERIFY_POLL_SEC=5

# Compare parallelism (cut wall-clock on ~180+ ops)
SOURCE_VALIDATION_COMPARE_WORKERS=8
SOURCE_VALIDATION_DISCOVERY_WORKERS=12

# ── CasePilot MCP (Generate in UI) ───────────────────────────────────────────
# Create key under CasePilot → Connections → CasePilot MCP API
CASEPILOT_API_KEY=
CASEPILOT_MCP_URL=https://casepilot.monotype-pp.com/mcp
# REST base for the jobs/status fallback (defaults to MCP host minus /mcp)
CASEPILOT_PUBLIC_URL=https://casepilot.monotype-pp.com
# Optional overrides (else NEXTGEN_UI_URL + OAUTH_USERNAME/OAUTH_PASSWORD)
# CASEPILOT_UI_BASE_URL=https://nextgen.monotype-pp.com
# CASEPILOT_UI_USERNAME=
# CASEPILOT_UI_PASSWORD=
CASEPILOT_UI_BROWSER=chrome
CASEPILOT_UI_HEADLESS=false
# Default parallel browsers for Generate-in-UI (omit on MCP call = full PP cap)
# 1 = serial · 2+ = N browsers at once (clamped by CasePilot MCP_MAX_PARALLEL_JOBS)
# CASEPILOT_MAX_PARALLEL=2
# Retries when Cloudflare LB returns Session not found (default 15)
# CASEPILOT_SESSION_RETRIES=15
