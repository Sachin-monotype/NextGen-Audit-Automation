.env
.env.*
!.env.example
backend/.venv/
frontend/node_modules/
frontend/dist/
__pycache__/
*.pyc
.DS_Store
.cursor/

# Runtime artifacts (validator output)
payload/raw/*.json
payload/enrich/*.json
payload/trigger/*.json
payload/graphql/*.json
payload/ingress/**/*.json
temp/*
result/*
reports/

# Local-only maintenance scripts (TestRail push, pack builders, generators)
# See local/README.md — tracked core scripts stay in scripts/ (dev.sh, ingest.sh, playwright.sh)
local/scripts/
.token_cache.json
!payload/raw/.gitkeep
!payload/enrich/.gitkeep
!payload/trigger/.gitkeep
!payload/graphql/.gitkeep
!temp/.gitkeep
!result/.gitkeep

# Generated QA packs — Excel / Postman / TouchPoint docs (local only)
*.xlsx
~$*.xlsx
*.postman_collection.json
docs/touchpoint/
docs/postman/
docs/mappings/*.xlsx
docs/mappings/*.postman_collection.json

# Local MCP secrets
.cursor/mcp.json
